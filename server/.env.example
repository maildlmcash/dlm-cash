# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dlm_crypto?schema=public"

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@dlmcrypto.com

# App Settings
APP_NAME=DLM Crypto Platform
APP_URL=http://localhost:3000
ADMIN_EMAIL=admin@dlmcrypto.com
ADMIN_PRIVATE_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Referral Settings
REFERRAL_CODE_LENGTH=8
MAX_REFERRAL_LEVELS=10

# ROI Settings
ROI_CALCULATION_CRON=0 0 * * *
SALARY_CALCULATION_CRON=0 0 1 * *
BLOCKCHAIN_MONITORING_CRON=*/2 * * * *

